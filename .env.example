APP_ENV=local
APP_NAME=UE AI Texturing Mock Server
APP_VERSION=0.1.0
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_DATA_DIR=server_data/jobs
JOB_STORAGE_DIR=server_data/jobs
MAX_UPLOAD_MB=50

# First-stage development stays mock-first and offline.
DEFAULT_REFERENCE_PROVIDER=mock
DEFAULT_MASK_PROVIDER=mock
DEFAULT_PBR_PROVIDER=mock_pbr
ENABLE_EXTERNAL_PROVIDERS=false

# Optional server-side reference provider config. Keep API keys on the server only.
PROVIDER_CONFIG_PATH=server_config.yaml

# Custom HTTP reference provider example values.
REFERENCE_CUSTOM_HTTP_ENDPOINT=
REFERENCE_CUSTOM_HTTP_MODEL=
REFERENCE_CUSTOM_HTTP_HEADERS_JSON={}
REFERENCE_CUSTOM_HTTP_REQUEST_TEMPLATE_JSON={}
REFERENCE_CUSTOM_HTTP_RESPONSE_MAPPING_JSON={}

# Doubao is intentionally a generic configurable HTTP adapter.
REFERENCE_DOUBAO_ENDPOINT=
REFERENCE_DOUBAO_MODEL=
REFERENCE_DOUBAO_HEADERS_JSON={}
REFERENCE_DOUBAO_REQUEST_TEMPLATE_JSON={}
REFERENCE_DOUBAO_RESPONSE_MAPPING_JSON={}
DOUBAO_API_KEY=

# ComfyUI provider config.
COMFYUI_BASE_URL=
REFERENCE_COMFYUI_ENDPOINT=
REFERENCE_COMFYUI_WORKFLOW_PATH=
REFERENCE_COMFYUI_HEADERS_JSON={}
REFERENCE_COMFYUI_RESPONSE_MAPPING_JSON={}
REFERENCE_COMFYUI_FIELD_MAPPINGS_JSON={}

# SAM is server-side only and disabled for local mock-first testing.
MASK_SAM_ENDPOINT=
MASK_SAM_MODEL_PATH=
SAM_MODEL_PATH=
MASK_SAM_COMMAND_TEMPLATE=
MASK_SAM_TIMEOUT=120

# Material Palette provider is server-side only. Keep local tests on mock/fake output.
MATERIAL_PALETTE_REPO_PATH=
MATERIAL_PALETTE_CONDA_ENV=
MATERIAL_PALETTE_COMMAND_TEMPLATE=
MATERIAL_PALETTE_TIMEOUT=900
MATERIAL_PALETTE_OUTPUT_DIR=
